# ── Supabase ──
# Get these from your Supabase project dashboard → Settings → API
VITE_SUPABASE_URL=https://wcdlyznqnjeoghsigbpt.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── AI Backend ──
# Development: can be empty (Vite proxy handles it)
# Production: /api/ai/chat (relative path to Vercel serverless function)
VITE_AI_BACKEND_URL=

# ── App Mode ──
VITE_APP_MODE=development

# ── DeepSeek API Key (SERVER-SIDE ONLY) ──
# Set this in Vercel Dashboard → Settings → Environment Variables
# NEVER commit this to git or include in client-side code
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ── CORS Allowed Origins (comma-separated) ──
# Set in Vercel Dashboard for production
ALLOWED_ORIGINS=http://localhost:5173,https://hsk.ncwu.site