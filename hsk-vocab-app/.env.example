# ── Supabase ──
# Get these from your Supabase project dashboard → Settings → API
VITE_SUPABASE_URL=https://wcdlyznqnjeoghsigbpt.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── AI Backend ──
# Option 1: Set VITE_DEEPSEEK_API_KEY — app calls DeepSeek directly from browser
# Option 2: Set VITE_AI_BACKEND_URL — custom backend/proxy
# If neither is set, AI chat uses offline fallback
VITE_DEEPSEEK_API_KEY=
VITE_AI_BACKEND_URL=

# ── App Mode ──
VITE_APP_MODE=development

# ── DeepSeek API Key (SERVER-SIDE ONLY) ──
# Used by Vercel serverless functions (see api/ai/chat)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ── CORS Allowed Origins (comma-separated) ──
ALLOWED_ORIGINS=http://localhost:5173,https://hsk.ncwu.site