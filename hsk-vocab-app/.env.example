# ── Supabase ──
# Get these from your Supabase project dashboard → Settings → API
VITE_SUPABASE_URL=https://wcdlyznqnjeoghsigbpt.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── AI Backend ──
# The browser calls the proxy at /api/ai/chat. To override the URL
# (rare), set VITE_AI_BACKEND_URL.
# The DeepSeek API key is SERVER-SIDE ONLY — do NOT set VITE_DEEPSEEK_API_KEY.
# Doing so would inline the key into the public JS bundle and leak it.
VITE_AI_BACKEND_URL=

# ── App Mode ──
VITE_APP_MODE=development

# ── DeepSeek API Key (SERVER-SIDE ONLY, Vercel env vars) ──
# Used by Vercel serverless functions (see api/ai/chat).
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ── CORS Allowed Origins (comma-separated, server-side) ──
ALLOWED_ORIGINS=http://localhost:5173,https://hsk.ncwu.site

# ── Upstash Redis (OPTIONAL, server-side) ──
# Used for shared rate-limiting, AI response caching, and circuit-breaker state
# across Vercel function instances. Without these, the app falls back to
# in-memory state (per-instance, lost on cold start) — fine for dev, not ideal
# for production at scale.
# Get these from https://console.upstash.com/ → your database → REST API.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=