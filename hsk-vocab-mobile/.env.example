# AI Backend Configuration
# Option 1 (easiest): Set a DeepSeek API key directly — the app calls DeepSeek
# EXPO_PUBLIC_DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
#
# Option 2: Set a custom backend proxy URL
# EXPO_PUBLIC_AI_BACKEND_URL=https://your-backend.example.com/api/ai/chat
#
# If neither is set, the AI chat will use an offline fallback response
EXPO_PUBLIC_DEEPSEEK_API_KEY=
EXPO_PUBLIC_AI_BACKEND_URL=

# Supabase credentials (shared with the web app)
# Copy this file to .env and fill in the real values from your Supabase dashboard.
# The anon key is safe to bundle in the app — RLS policies on the server
# protect the data. NEVER put the service_role key here.
#
# Get these from your Supabase project dashboard → Settings → API
# Example:
#   EXPO_PUBLIC_SUPABASE_URL=https://wcdlyznqnjeoghsigbpt.supabase.co
#   EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key...
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=