# AI Backend Proxy URL (dev only — for production, set in app.json)
# The backend proxy holds the API key securely server-side
EXPO_PUBLIC_AI_BACKEND_URL=http://localhost:3000

# Data source: "sqlite" (local) or "supabase" (cloud)
# Set this in app.json -> expo.extra.dataSource
#   - "sqlite"   → on-device SQLite (no backend needed, dev mode)
#   - "supabase" → shared Supabase backend (same database as web app)
#
# Supabase credentials are also set in app.json -> expo.extra:
#   - supabaseUrl:     https://your-project.supabase.co
#   - supabaseAnonKey: your-anon-key