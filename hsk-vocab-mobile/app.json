{
  "expo": {
    "name": "HSK Vocab",
    "slug": "hsk-vocab-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hskvocab",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "privacyPolicyUrl": "https://hskvocab.com/privacy",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hskvocab.mobile",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Microphone access is needed for voice input and speech practice."
      },
      "associatedDomains": ["applinks:hskvocab.com"]
    },
    "android": {
      "package": "com.hskvocab.mobile",
      "minSdkVersion": 24,
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "enableProguardOnRelease": true,
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#a855f7",
        "foregroundImage": "./assets/icon.png"
      },
      "permissions": [
        "INTERNET",
        "RECORD_AUDIO",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "POST_NOTIFICATIONS"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Microphone access is needed for voice input and speech practice."
        }
      ],
      [
        "expo-sqlite",
        {
          "enableSQLCipher": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#a855f7",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "dark": {
            "backgroundColor": "#1e1b4b"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#a855f7",
          "defaultChannel": "study-reminders"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "dataSource": "sqlite",
      "aiBackendUrl": "https://hsk.ncwu.site/api/ai/chat",
      "eas": {
        "projectId": "ef0911dd-e07f-4050-aeca-83349ffa0d66"
      }
    }
  }
}
