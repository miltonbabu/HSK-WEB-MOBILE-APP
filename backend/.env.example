# DeepSeek API key — NEVER exposed to client
# Get your key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Server port
PORT=3000

# Allowed origins (comma-separated, for CORS)
# Dev:  http://localhost:5173,http://localhost:8081,exp://*
# Prod: https://your-app.com,https://your-backend.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081,exp://*